## Payments (Paymob)
# Base64 API key or plain key (depends on your Paymob account)
VITE_PAYMOB_API_KEY=
VITE_PAYMOB_WALLET_INTEGRATION_ID=
VITE_PAYMOB_CARD_INTEGRATION_ID=
VITE_PAYMOB_CARD_IFRAME_ID=
VITE_PAYMOB_WALLET_IFRAME_ID=

## Manual payments (Vodafone Cash / InstaPay) - display only
VITE_MANUAL_PAYMENT_PHONE=
VITE_FREE_DELIVERY_THRESHOLD=

## Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

## Dev fallback admin login (used only when Firebase config is missing)
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=
VITE_DEV_ADMIN_ROLE=admin
VITE_DEV_ADMIN_BRANCH_ID=mansoura

## Email-based admin access fallback (when /admins docs are missing)
VITE_OWNER_EMAIL=
VITE_ADMIN_EMAILS=
VITE_DEFAULT_ADMIN_BRANCH_ID=mansoura
