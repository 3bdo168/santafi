rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdminOrOwner() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role in ["owner", "admin"];
    }

    function isOwner() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role == "owner";
    }

    function isAdminForBranch(branchId) {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role == "admin" &&
        adminDoc().data.branchId == branchId;
    }

    function isValidClientOrderCreate(branchId) {
      return request.resource.data.clientUid == request.auth.uid &&
        request.resource.data.branchId == branchId;
    }

    function isCouponUsageIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["usageCount", "updatedAt"]) &&
        request.resource.data.usageCount == resource.data.usageCount + 1 &&
        request.resource.data.updatedAt is timestamp &&
        (!resource.data.keys().hasAny(["usageLimit"]) ||
          resource.data.usageLimit == null ||
          resource.data.usageCount < resource.data.usageLimit) &&
        (!resource.data.keys().hasAny(["ownerUid"]) ||
          resource.data.ownerUid == request.auth.uid);
    }

    // ── Static collections ──────────────────────────────────────────

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /clients/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /subscribers/{subscriberId} {
      allow create: if
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.source == "homepage";
      allow read, update, delete: if isAdminOrOwner();
    }

    match /all_orders/{docId} {
      allow create: if isSignedIn() && isValidClientOrderCreate(request.resource.data.branchId);
      allow read: if isSignedIn() && (
        resource.data.clientUid == request.auth.uid ||
        isAdminOrOwner()
      );
      allow update: if isAdminOrOwner();
    }

    match /weeklyReports/{doc}/reports/{reportId} {
      allow read, write: if isOwner();
    }

    match /ownerTargets/{doc}/data/{docId} {
      allow read, write: if isOwner();
    }

    match /modifierGroups/{groupId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
      match /options/{optionId} {
        allow read: if true;
        allow write: if isAdminOrOwner();
      }
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /offerItems/{itemId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /configs/{docId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // ✅ عجلة الحظ — كانت ناقصة من الـ rules القديمة
    match /spinConfig/{docId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /wheelSettings/{docId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }


    match /spinLogs/{dateId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdminOrOwner();
    }

    match /spinUsers/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrOwner());
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.prizeId is string &&
        request.resource.data.prizeLabel is string &&
        request.resource.data.time is timestamp;
      allow update: if false;
      allow delete: if isAdminOrOwner();
    }

    // ── Branch-level collections (direct access) ────────────────────

    match /{branchId}/deliveryZones/{doc=**} {
      allow read: if true;
      allow write: if isOwner() || isAdminForBranch(branchId);
    }

    // ✅ تغيير: العميل يقرأ الكوبونات في الـ checkout
    match /{branchId}/discountCoupons/{doc=**} {
      allow read: if true;
      allow create, delete: if isOwner() || isAdminForBranch(branchId);
      allow update: if isOwner() || isAdminForBranch(branchId) ||
        (isSignedIn() && isCouponUsageIncrement());
    }

    match /{branchId}/deliveryConfig/{doc=**} {
      allow read: if true;
      allow write: if isOwner() || isAdminForBranch(branchId);
    }

    // ── Branch-level /data/ sub-collections ─────────────────────────

    match /{branchId}/{section}/data/{docId} {

      allow read: if section == "products" || section == "categories";
      allow write: if (section == "products" || section == "categories") &&
        (isOwner() || isAdminForBranch(branchId));

      allow create: if section == "orders" && isSignedIn() && isValidClientOrderCreate(branchId);
      allow read, update, delete: if section == "orders" && (isOwner() || isAdminForBranch(branchId));

      allow read, write: if section == "archived_orders" && (isOwner() || isAdminForBranch(branchId));

      // ✅ تغيير: قراءة الكوبونات للعملاء + تحديث usageCount فقط بعد الطلب
      allow read: if section == "discountCoupons";
      allow create, delete: if section == "discountCoupons" && (isOwner() || isAdminForBranch(branchId));
      allow update: if section == "discountCoupons" && (
        (isOwner() || isAdminForBranch(branchId)) ||
        (isSignedIn() && isCouponUsageIncrement())
      );

      allow read, write: if section == "deliveryZones" && (isOwner() || isAdminForBranch(branchId));

      allow read: if section == "recommendations";
      allow write: if section == "recommendations" && (isOwner() || isAdminForBranch(branchId));

      allow read: if section == "offers";
      allow write: if section == "offers" && (isOwner() || isAdminForBranch(branchId));

      allow read: if section == "offerItems";
      allow write: if section == "offerItems" && (isOwner() || isAdminForBranch(branchId));

      allow read: if section == "offersPageConfig";
      allow write: if section == "offersPageConfig" && (isOwner() || isAdminForBranch(branchId));

      allow read: if section == "deliveryConfig";
      allow write: if section == "deliveryConfig" && (isOwner() || isAdminForBranch(branchId));
    }
  }
}
