rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdminOrOwner() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role in ["owner", "admin"];
    }

    function isOwner() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role == "owner";
    }

    function isAdminForBranch(branchId) {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role == "admin" &&
        adminDoc().data.branchId == branchId;
    }

    function isValidClientOrderCreate(branchId) {
      // Basic schema validation for client-created orders to reduce tampering.
      return
        request.resource.data.clientUid == request.auth.uid &&
        request.resource.data.branchId == branchId &&
        request.resource.data.status in ["pending", "pending_payment"] &&
        request.resource.data.total is number && request.resource.data.total >= 0 &&
        request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 &&
        request.resource.data.deliveryFee is number && request.resource.data.deliveryFee >= 0 &&
        request.resource.data.items is list &&
        request.resource.data.createdAt is timestamp;
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /clients/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /subscribers/{subscriberId} {
      allow create: if
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.source == "homepage";
      allow read, update, delete: if isAdminOrOwner();
    }

    // ✅ all_orders
    match /all_orders/{docId} {
      // العميل ينشئ أوردر لنفسه فقط
      allow create: if isSignedIn() && isValidClientOrderCreate(request.resource.data.branchId);

      allow read: if isSignedIn() && (
        resource.data.clientUid == request.auth.uid ||
        isAdminOrOwner()
      );

      allow update: if isAdminOrOwner();
    }

    match /weeklyReports/{doc}/reports/{reportId} {
      allow read, write: if isOwner();
    }

    // ✅ ownerTargets — التارجتات (للـ owner فقط)
    match /ownerTargets/{doc}/data/{docId} {
      allow read, write: if isOwner();
    }

    // ✅ modifierGroups (global) — قراءة للكل، كتابة للأدمن/أونر
    match /modifierGroups/{groupId} {
      allow read: if true;
      allow write: if isAdminOrOwner();

      match /options/{optionId} {
        allow read: if true;
        allow write: if isAdminOrOwner();
      }
    }

    // ✅ offers (global) — قراءة للكل، كتابة للأونر/أدمن
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // ✅ offerItems (global) — قراءة للكل، كتابة للأدمن/أونر
    match /offerItems/{itemId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    // ✅ configs (global) — قراءة للكل، كتابة للأدمن/أونر
    match /configs/{docId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /{branchId}/{section}/data/{docId} {

      // ── products & categories — القراءة للكل، الكتابة للأدمن/أونر ──
      allow read: if section == "products" || section == "categories";
      allow write: if (section == "products" || section == "categories") &&
        (isOwner() || isAdminForBranch(branchId));

      // ── orders — إنشاء للعملاء، قراءة/تعديل/حذف للأدمن/أونر ──
      allow create: if section == "orders" && isSignedIn() && isValidClientOrderCreate(branchId);
      allow read, update, delete: if section == "orders" && (isOwner() || isAdminForBranch(branchId));

      // ── archived_orders — قراءة/كتابة للأدمن/أونر ──
      allow read, write: if section == "archived_orders" && (isOwner() || isAdminForBranch(branchId));

      // ✅ discountCoupons — قراءة/كتابة للأدمن/أونر (كانت ناقصة!)
      allow read, write: if section == "discountCoupons" && (isOwner() || isAdminForBranch(branchId));

      // ✅ deliveryZones — قراءة/كتابة للأدمن/أونر (كانت ناقصة!)
      allow read, write: if section == "deliveryZones" && (isOwner() || isAdminForBranch(branchId));

      // ✅ recommendations — القراءة للكل (عشان الـ popup في الـ checkout)، الكتابة للأدمن/أونر
      allow read: if section == "recommendations";
      allow write: if section == "recommendations" && (isOwner() || isAdminForBranch(branchId));

      // ✅ offers (branch scoped) — قراءة للكل، كتابة للأدمن/أونر
      allow read: if section == "offers";
      allow write: if section == "offers" && (isOwner() || isAdminForBranch(branchId));

      // ✅ offerItems (branch scoped) — قراءة للكل، كتابة للأدمن/أونر
      allow read: if section == "offerItems";
      allow write: if section == "offerItems" && (isOwner() || isAdminForBranch(branchId));

      // ✅ offersPageConfig (branch scoped) — قراءة للكل، كتابة للأدمن/أونر
      allow read: if section == "offersPageConfig";
      allow write: if section == "offersPageConfig" && (isOwner() || isAdminForBranch(branchId));

      // ✅ deliveryConfig (branch scoped) — قراءة للكل، كتابة للأدمن/أونر
      allow read: if section == "deliveryConfig";
      allow write: if section == "deliveryConfig" && (isOwner() || isAdminForBranch(branchId));
    }
  }
}
